<?xml version="1.0" encoding="UTF-8"?>
<!--
  SoFit 구조화 로깅 설정 (sofit-admin)
  - local  : 사람이 읽기 좋은 콘솔 패턴 (개발용)
  - dev/test/prod : JSON (LogstashEncoder) → stdout → Docker json-file → Promtail → Loki
  - traceId / sourceSystem 은 MDC(TraceIdFilter, 배치 스케줄러)에서 주입
-->
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <!-- 로컬: 사람이 읽기 좋은 콘솔 -->
    <springProfile name="local">
        <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level [%X{traceId:-}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
    </springProfile>

    <!-- 배포 환경: JSON (Loki 검색용) -->
    <springProfile name="dev,test,prod">
        <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- 추적/시스템 식별자는 본문 JSON 필드로 (라벨로 쓰지 않음 = 카디널리티 보호) -->
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>sourceSystem</includeMdcKeyName>
                <customFields>{"app":"${appName}"}</customFields>
            </encoder>
        </appender>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- 운영 소음 억제 -->
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.springframework.web" level="INFO"/>
</configuration>
