{
  "name": "sofit-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "user-front",
    "admin-front"
  ],
  "scripts": {
    "dev:user": "npm run dev --workspace=user-front",
    "dev:admin": "npm run dev --workspace=admin-front",
    "build:user": "npm run build --workspace=user-front",
    "build:admin": "npm run build --workspace=admin-front",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.0",
    "lucide-react": "^1.16.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.0",
    "tailwindcss": "^4.3.0",
    "turbo": "^2.5.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
